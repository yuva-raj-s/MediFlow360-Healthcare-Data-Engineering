{
  "kafka_topics": [
    {
      "name": "mrhs.icu.vitals",
      "description": "Real-time ICU vital sign readings from bedside monitors across all 4 MRHS hospitals",
      "source_system": "S7_ICU_MONITORS",
      "partitions": 12,
      "replication_factor": 3,
      "retention_ms": 604800000,
      "retention_bytes": -1,
      "cleanup_policy": "delete",
      "compression_type": "gzip",
      "max_message_bytes": 1048576,
      "consumer_groups": [
        "mediflow360-vitals-consumer-grp",
        "mediflow360-dq-monitor-grp"
      ],
      "schema": "vitals_schema.avsc",
      "expected_tps": 80,
      "sla_lag_threshold": 500,
      "bronze_delta_table": "mediflow_prod.bronze.icu_vitals_stream",
      "watermark_delay": "5 minutes",
      "tags": ["realtime", "icu", "clinical", "pii"]
    },
